{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Humanity Chain Record v1",
  "type": "object",
  "required": ["record_id", "created_at", "title", "record_type", "witness_type", "author", "content_hash", "archive_ref", "verification_status"],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^HC-[A-Z0-9]+-[0-9]{4}-[0-9]{4}$",
      "description": "Unique record identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Record title"
    },
    "record_type": {
      "type": "string",
      "enum": ["ai_witness", "human_witness", "multi_model_record", "protocol_note"],
      "description": "Type of record"
    },
    "witness_type": {
      "type": "string",
      "enum": ["ai", "human", "multi"],
      "description": "Witness type"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "description": "Author name or identifier"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA256 hash of content"
    },
    "archive_ref": {
      "type": "string",
      "description": "Reference to archived record"
    },
    "verification_status": {
      "type": "string",
      "enum": ["draft", "reviewed", "verified", "archived"],
      "description": "Current verification status"
    },
    "description": {
      "type": "string",
      "description": "Record description"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Record tags"
    }
  }
}