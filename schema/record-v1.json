{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Humanity Chain Record Schema",
  "description": "Standard record schema for Humanity Chain",
  "type": "object",

  "required": [
    "id",
    "timestamp",
    "title",
    "source",
    "content",
    "witnesses",
    "status",
    "prev_hash",
    "hash"
  ],

  "properties": {
    "id": {
      "type": "string",
      "description": "Unique record identifier",
      "pattern": "^HC-[A-Z0-9]+-[0-9]{4}$"
    },

    "timestamp": {
      "type": "string",
      "description": "Record creation timestamp",
      "format": "date-time"
    },

    "title": {
      "type": "string",
      "description": "Short title of the record"
    },

    "source": {
      "type": "string",
      "description": "Source system or contributor"
    },

    "content": {
      "type": "string",
      "description": "Main record content or summary"
    },

    "witnesses": {
      "type": "array",
      "minItems": 1,
      "description": "Witnesses connected to this record",
      "items": {
        "type": "string"
      }
    },

    "status": {
      "type": "string",
      "description": "Current verification status",
      "enum": [
        "pending",
        "verified",
        "archived"
      ]
    },

    "prev_hash": {
      "type": "string",
      "description": "Hash of the previous record."
    },

    "hash": {
      "type": "string",
      "description": "SHA-256 hash of this record.",
      "pattern": "^$|^[a-fA-F0-9]{64}$"
    }
  },

  "additionalProperties": false
}
